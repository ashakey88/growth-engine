# ── Storage backend ──────────────────────────────────────────────
# "local" writes Parquet to ./data/raw (default, zero cost).
# "r2" writes Parquet to a Cloudflare R2 bucket (S3-compatible).
STORAGE_BACKEND=local

# ── Cloudflare R2 (only needed when STORAGE_BACKEND=r2) ───────────
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_BUCKET=growth-engine
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ── Shopify (optional) ───────────────────────────────────────────
# When both are set, the pipeline pulls real orders instead of mock data.
# Create a custom app in your store admin and copy the Admin API access token.
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=
