# ── Storage backend ──────────────────────────────────────────────
# "local" writes Parquet under ./data (default, zero cost).
# "r2" reads/writes a Cloudflare R2 bucket (S3-compatible).
STORAGE_BACKEND=local

# ── Cloudflare R2 (only needed when STORAGE_BACKEND=r2) ───────────
R2_ACCOUNT_ID=
R2_BUCKET=growth-engine
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Optional: set R2_ENDPOINT to override the derived account endpoint.
R2_ENDPOINT=

# ── Shopify (optional) ───────────────────────────────────────────
# When both are set, `python run_pipeline.py shopify` pulls real orders.
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=
