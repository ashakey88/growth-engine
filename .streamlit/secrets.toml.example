# Copy this into the Streamlit Cloud app's Secrets (Manage app → Settings →
# Secrets), or to .streamlit/secrets.toml locally. Streamlit exposes these as
# environment variables, which config.py reads.
#
# Leave STORAGE_BACKEND unset (or "local") to have the app self-seed mock data.
# Set it to "r2" to read the data the pipeline built in Cloudflare R2.

STORAGE_BACKEND = "r2"
R2_ACCOUNT_ID = "your-cloudflare-account-id"
R2_BUCKET = "growth-engine"
R2_ACCESS_KEY_ID = "your-r2-access-key-id"
R2_SECRET_ACCESS_KEY = "your-r2-secret-access-key"
